#!/bin/sh

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="${2:-}"
INITIALS="AGO"

# No modificar commits automáticos de merge o squash.
case "$COMMIT_SOURCE" in
    merge|squash)
        exit 0
        ;;
esac

# Obtener la rama actual.
# En detached HEAD no se modifica el mensaje.
BRANCH=$(git symbolic-ref --quiet --short HEAD 2>/dev/null) || exit 0

PREFIX="[$INITIALS] - $BRANCH - "

# Leer la primera línea del mensaje.
FIRST_LINE=$(sed -n '1p' "$COMMIT_MSG_FILE")

# Evitar romper commits usados por git rebase --autosquash.
case "$FIRST_LINE" in
    fixup\!*|squash\!*|amend\!*)
        exit 0
        ;;
esac

# Evitar agregar el prefijo más de una vez.
case "$FIRST_LINE" in
    "$PREFIX"*)
        exit 0
        ;;
esac

# Crear el mensaje nuevo conservando mensajes multilínea.
TEMP_FILE=$(mktemp) || exit 1

{
    printf '%s' "$PREFIX"
    cat "$COMMIT_MSG_FILE"
} > "$TEMP_FILE"

cat "$TEMP_FILE" > "$COMMIT_MSG_FILE"
rm -f "$TEMP_FILE"

exit 0

#!/bin/sh

set -u

printf '%s\n' "Ejecutando validaciones pre-commit..."

FAILED=0

# Obtener scripts shell agregados o modificados en el commit.
STAGED_SHELL_FILES=$(
    git diff --cached \
        --name-only \
        --diff-filter=ACMR \
    | grep -E '\.(sh|bash)$' || true
)

for FILE in $STAGED_SHELL_FILES; do
    if [ ! -f "$FILE" ]; then
        continue
    fi

    printf 'Validando sintaxis: %s\n' "$FILE"

    if ! bash -n "$FILE"; then
        printf 'ERROR: Sintaxis inválida en %s\n' "$FILE" >&2
        FAILED=1
    fi
done

# Ejecutar validación particular del repositorio cuando exista.
if [ -x ".githooks/pre-commit" ]; then
    printf '%s\n' "Ejecutando .githooks/pre-commit..."
    ./.githooks/pre-commit || FAILED=1
fi

if [ "$FAILED" -ne 0 ]; then
    printf '%s\n' "Commit cancelado por errores de validación." >&2
    exit 1
fi

printf '%s\n' "Validaciones pre-commit completadas."
exit 0

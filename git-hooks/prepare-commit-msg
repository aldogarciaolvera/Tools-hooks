#!/bin/sh

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="${2:-}"
INITIALS="${GIT_AUTHOR_INITIALS:-AGO}"

# No modificar mensajes generados para merge o squash.
case "$COMMIT_SOURCE" in
    merge|squash)
        exit 0
        ;;
esac

# No modificar commits si Git está en detached HEAD.
BRANCH=$(git symbolic-ref --quiet --short HEAD 2>/dev/null) || exit 0

PREFIX="[$INITIALS] - $BRANCH - "
FIRST_LINE=$(sed -n '1p' "$COMMIT_MSG_FILE")

# Respetar commits especiales de autosquash.
case "$FIRST_LINE" in
    fixup\!*|squash\!*|amend\!*)
        exit 0
        ;;
esac

# Evitar duplicar el prefijo.
case "$FIRST_LINE" in
    "$PREFIX"*)
        exit 0
        ;;
esac

TEMP_FILE=$(mktemp) || exit 1

{
    printf '%s' "$PREFIX"
    cat "$COMMIT_MSG_FILE"
} > "$TEMP_FILE"

cat "$TEMP_FILE" > "$COMMIT_MSG_FILE"
rm -f "$TEMP_FILE"

exit 0

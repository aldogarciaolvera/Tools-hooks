#!/bin/sh

COMMIT_MSG_FILE="$1"
FIRST_LINE=$(sed -n '1p' "$COMMIT_MSG_FILE")

# Permitir commits automáticos.
case "$FIRST_LINE" in
    Merge\ *|Revert\ *|fixup\!*|squash\!*|amend\!*)
        exit 0
        ;;
esac

# Formato esperado:
# [AGO] - rama - tipo: descripción
PATTERN='^\[[A-Za-z0-9_-]+\] - [^ ]+ - (feat|fix|docs|refactor|test|mnto|build|ci|perf|style|revert)(\([A-Za-z0-9._/-]+\))?!?: .+'

if ! printf '%s\n' "$FIRST_LINE" | grep -Eq "$PATTERN"; then
    cat >&2 <<'EOF'

ERROR: El mensaje del commit no cumple el formato requerido.

Formato:

  [INICIALES] - rama - tipo: descripción

Ejemplos:

  [AGO] - main - feat: agrega respaldo remoto
  [AGO] - develop - fix: corrige validación SHA-256
  [AGO] - main - docs: actualiza README
  [AGO] - main - feat(postgres): agrega restauración selectiva

Tipos permitidos:

  feat fix docs refactor test mnto build ci perf style revert

EOF
    exit 1
fi

exit 0
